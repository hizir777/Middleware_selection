# ═══════════════════════════════════════════════════
# Middleware Selection — Environment Variables
# ═══════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun:
#   cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── Sunucu ────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT (JSON Web Token) ─────────────────────────
# Güçlü bir rastgele string kullanın (min 32 karakter)
JWT_SECRET=CHANGE_ME_super_secret_key_min_32_chars
JWT_EXPIRES_IN=1h

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Rate Limiting ─────────────────────────────────
# Kritik rotalar (login, register) — dakika başına
RATE_LIMIT_CRITICAL=10
# Genel rotalar — dakika başına
RATE_LIMIT_GENERAL=2000

# ─── Telegram Bildirimleri ─────────────────────────
# @BotFather üzerinden bot oluşturup token alın
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ─── CORS ──────────────────────────────────────────
CORS_ORIGIN=*
