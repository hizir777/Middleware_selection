# Auto detect text files and perform LF normalization
* text=auto

# Enforce Unix line endings (LF) for all source code
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.sh text eol=lf

# Windows specific scripts should keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Explicitly declare binary files to prevent Git from modifying them
*.db binary
*.sqlite binary
*.sqlite3 binary

# Image files are binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
